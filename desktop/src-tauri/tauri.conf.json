{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Warpforge",
  "version": "0.1.0",
  "identifier": "dev.warpforge.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Warpforge",
        "width": 1360,
        "height": 860,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' ws://127.0.0.1:* ws://localhost:*"
    }
  },
  "bundle": {
    "active": false
  }
}
