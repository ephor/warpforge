{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Warpforge",
  "version": "0.1.0",
  "identifier": "dev.warpforge.desktop",
  "build": {
    "beforeDevCommand": "node scripts/stage-sidecar.mjs --profile debug --no-target && npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "node scripts/stage-sidecar.mjs --profile release && npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Warpforge",
        "width": 1360,
        "height": 860,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' ws://127.0.0.1:* ws://localhost:*"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "externalBin": ["binaries/warpforge"],
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDc2Rjk5RDZDMjFFODhCREIKUldUYmkrZ2hiSjM1ZGd2NmptODMvZWlJTFVzK3BXZTBTWWkvT215Y0dpT3JsSlpramVCcTdIakkK",
      "endpoints": [
        "https://github.com/ephor/warpforge/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
